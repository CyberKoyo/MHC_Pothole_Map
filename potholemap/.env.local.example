# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# URL of the FastAPI backend.
# When testing from another device (phone, second laptop), change this to your
# machine's LAN or Tailscale IP so the other device can reach the API.
# Example: NEXT_PUBLIC_API_BASE=http://192.168.1.42:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Comma-separated list of IPs/hostnames that are allowed to access Next.js dev
# resources (JS chunks, HMR socket) from a non-localhost origin.
# Set this to your machine's LAN or Tailscale IP when accessing the dev server
# from another device, otherwise the map will show "Loading..." forever.
# Example: ALLOWED_DEV_ORIGINS=192.168.1.42
# Multiple: ALLOWED_DEV_ORIGINS=192.168.1.42,100.82.117.123
ALLOWED_DEV_ORIGINS=
